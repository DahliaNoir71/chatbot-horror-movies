{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "API Uptime",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "up{job=\"horrorbot-api\"}",
          "legendFormat": "API",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "DB Connection Pool (active / idle)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "horrorbot_db_connection_pool_size{state=\"active\"}",
          "legendFormat": "Active",
          "refId": "A"
        },
        {
          "expr": "horrorbot_db_connection_pool_size{state=\"idle\"}",
          "legendFormat": "Idle",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "stacking": { "mode": "normal" },
            "fillOpacity": 30
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Messages per Session (median)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(horrorbot_session_message_count_bucket[5m]))",
          "legendFormat": "Median",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "DB Query Latency P95 by Operation",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (operation, le) (rate(horrorbot_db_query_duration_seconds_bucket[5m])))",
          "legendFormat": "P95 {{operation}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (operation, le) (rate(horrorbot_db_query_duration_seconds_bucket[5m])))",
          "legendFormat": "P50 {{operation}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.25 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "DB Query Rate by Operation",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum by (operation) (rate(horrorbot_db_query_duration_seconds_count[5m]))",
          "legendFormat": "{{operation}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["horrorbot", "infra"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "HorrorBot — Infrastructure",
  "uid": "horrorbot-infra"
}
