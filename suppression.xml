<?xml version="1.0" encoding="UTF-8"?>
<!--
  OWASP Dependency-Check Suppression File
  Project: HorrorBot

  This file suppresses known false positives and CVEs on transitive
  dependencies that are not exposed in HorrorBot's architecture.

  Each suppression MUST include a justification in <notes>.
  Suppressions are reviewed on each pipeline update.
-->
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

  <!-- =================================================================
       litellm — Transitive dependency of Crawl4AI
       =================================================================
       HorrorBot uses llama-cpp-python directly (no LangChain/LiteLLM).
       litellm is pulled transitively by Crawl4AI and is never imported,
       configured, or exposed. The CVEs concern litellm's JWT proxy
       authentication and config update endpoints, which are never
       instantiated in HorrorBot's architecture.
  -->
  <suppress>
    <notes>CVE-2026-35030: litellm JWT auth bypass — transitive dep of Crawl4AI, not exposed</notes>
    <packageUrl regex="true">^pkg:pypi/.*litellm@.*$</packageUrl>
    <cve>CVE-2026-35030</cve>
  </suppress>

  <suppress>
    <notes>CVE-2026-35029: litellm /config/update RCE — transitive dep of Crawl4AI, not exposed</notes>
    <packageUrl regex="true">^pkg:pypi/.*litellm@.*$</packageUrl>
    <cve>CVE-2026-35029</cve>
  </suppress>

  <suppress>
    <notes>CVE-2026-42271 (CVSS 8.7): unclecode-litellm — transitive dep bundled by crawl4ai; not imported or exposed. Review 2026-11-19.</notes>
    <packageUrl regex="true">^pkg:pypi/.*litellm@.*$</packageUrl>
    <cve>CVE-2026-42271</cve>
  </suppress>

  <suppress>
    <notes>CVE-2026-42203 (CVSS 8.6): unclecode-litellm — transitive dep bundled by crawl4ai; not imported or exposed. Review 2026-11-19.</notes>
    <packageUrl regex="true">^pkg:pypi/.*litellm@.*$</packageUrl>
    <cve>CVE-2026-42203</cve>
  </suppress>

  <suppress>
    <notes>CVE-2026-40217 (CVSS 8.8): unclecode-litellm — transitive dep bundled by crawl4ai; not imported or exposed. Review 2026-11-19.</notes>
    <packageUrl regex="true">^pkg:pypi/.*litellm@.*$</packageUrl>
    <cve>CVE-2026-40217</cve>
  </suppress>

  <!-- =================================================================
       lxml — Transitive dependency of Crawl4AI (>=5.4.0)
       =================================================================
       5.4.0 is the latest available release; no upstream patch exists.
       lxml is used by Crawl4AI's HTML parser, not by HorrorBot directly.
  -->
  <suppress>
    <notes>CVE-2026-41066 (CVSS 7.5): lxml 5.4.0 — transitive dep via crawl4ai; latest available version, no fix. Review 2026-11-19.</notes>
    <packageUrl regex="true">^pkg:pypi/lxml@.*$</packageUrl>
    <cve>CVE-2026-41066</cve>
  </suppress>

