<?xml version="1.0" encoding="UTF-8"?>
<!--
  OWASP Dependency-Check Suppression File
  Project: HorrorBot

  This file suppresses known false positives and CVEs on transitive
  dependencies that are not exposed in HorrorBot's architecture.

  Each suppression MUST include a justification in <notes>.
  Suppressions are reviewed on each pipeline update.
-->
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

  <!-- =================================================================
       litellm — Transitive dependency of Crawl4AI
       =================================================================
       HorrorBot uses llama-cpp-python directly (no LangChain/LiteLLM).
       litellm is pulled transitively by Crawl4AI and is never imported,
       configured, or exposed. The CVEs concern litellm's JWT proxy
       authentication and config update endpoints, which are never
       instantiated in HorrorBot's architecture.
  -->
  <suppress>
    <notes>CVE-2026-35030: litellm JWT auth bypass — transitive dep of Crawl4AI, not exposed</notes>
    <packageUrl regex="true">^pkg:pypi/.*litellm@.*$</packageUrl>
    <cve>CVE-2026-35030</cve>
  </suppress>

  <suppress>
    <notes>CVE-2026-35029: litellm /config/update RCE — transitive dep of Crawl4AI, not exposed</notes>
    <packageUrl regex="true">^pkg:pypi/.*litellm@.*$</packageUrl>
    <cve>CVE-2026-35029</cve>
  </suppress>

  <suppress>
    <notes>CVE-2026-42271 (CVSS 8.7): unclecode-litellm — transitive dep bundled by crawl4ai; not imported or exposed. Review 2026-11-19.</notes>
    <packageUrl regex="true">^pkg:pypi/.*litellm@.*$</packageUrl>
    <cve>CVE-2026-42271</cve>
  </suppress>

  <suppress>
    <notes>CVE-2026-42203 (CVSS 8.6): unclecode-litellm — transitive dep bundled by crawl4ai; not imported or exposed. Review 2026-11-19.</notes>
    <packageUrl regex="true">^pkg:pypi/.*litellm@.*$</packageUrl>
    <cve>CVE-2026-42203</cve>
  </suppress>

  <suppress>
    <notes>CVE-2026-40217 (CVSS 8.8): unclecode-litellm — transitive dep bundled by crawl4ai; not imported or exposed. Review 2026-11-19.</notes>
    <packageUrl regex="true">^pkg:pypi/.*litellm@.*$</packageUrl>
    <cve>CVE-2026-40217</cve>
  </suppress>

  <!-- =================================================================
       prometheus-client — Direct Python dependency (>=0.23.1, locked 0.25.0)
       =================================================================
       Used for local Prometheus metrics exposition (/metrics endpoint).
       HorrorBot is localhost-only; the endpoint is never publicly exposed.
       0.25.0 is the latest release (2026-04-09); no upstream patch available.
  -->
  <suppress>
    <notes>CVE-2026-42154 (CVSS 7.5): prometheus-client 0.25.0 — metrics endpoint is localhost-only, not publicly exposed; no fix available. Review 2026-11-19.</notes>
    <packageUrl regex="true">^pkg:pypi/prometheus.client@.*$</packageUrl>
    <cve>CVE-2026-42154</cve>
  </suppress>

  <!-- =================================================================
       ws — Transitive npm devDep via puppeteer-core → chromium-bidi
       =================================================================
       ws@8.19.0 is pulled by chromium-bidi (devDep), used only by
       puppeteer-core for lighthouse a11y/perf testing. Not bundled or
       exposed in the production build; no public WebSocket endpoint.
  -->
  <suppress>
    <notes>CVE-2026-45736 (CVSS 7.5): ws 8.19.0 — transitive devDep via puppeteer-core/chromium-bidi; not in production runtime, no public WS endpoint. Review 2026-11-19.</notes>
    <packageUrl regex="true">^pkg:npm/ws@.*$</packageUrl>
    <cve>CVE-2026-45736</cve>
  </suppress>

  <!-- =================================================================
       basic-ftp — Transitive npm dependency via lighthouse (devDep)
       =================================================================
       Not used at runtime; brought in by lighthouse (perf/a11y testing).
       No override available without breaking the lighthouse integration.
  -->
  <suppress>
    <notes>CVE-2026-41324 (CVSS 7.5): basic-ftp — transitive devDep via lighthouse; not used at runtime. Review 2026-11-19.</notes>
    <packageUrl regex="true">^pkg:npm/basic-ftp@.*$</packageUrl>
    <cve>CVE-2026-41324</cve>
  </suppress>

</suppressions>